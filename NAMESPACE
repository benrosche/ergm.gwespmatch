# 1. Load the compiled C code
useDynLib(ergm.gwespmatch)

# 2. Export your initialization function
# This allows the main 'ergm' package to find your new term
export(InitErgmTerm.gwespmatch)

# The shared-partner cache auxiliary must also be visible to ergm's term lookup.
export(InitErgmTerm..gwespmatch.spcache)

# 3. Import necessary packages
import(ergm)
import(network)
